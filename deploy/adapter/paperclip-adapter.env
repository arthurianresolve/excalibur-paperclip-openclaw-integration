# Paperclip ↔ OpenClaw adapter environment template
# Copy this alongside your Compose invocation and fill in the secrets/URLs.

# HTTP port the adapter listens on (default 3000)
PORT=3210

# OpenClaw gateway settings
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_ACTION_PATH=/gateway/actions
OPENCLAW_AUTH_TOKEN=

# Paperclip callback URL (must be reachable by OpenClaw)
PAPERCLIP_CALLBACK_URL=http://paperclip-controller:3100

# Comma-separated allowlist for actions (read-only first, mutating last)
TRUSTED_ACTIONS=queryAuditLogs,runTrustedSkill
