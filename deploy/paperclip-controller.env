# Paperclip controller environment template
# Fill in values as needed before deployment.
# Repo-accurate note: the Paperclip Dockerfile defaults HOME/PAPERCLIP_HOME to /paperclip.

PAPERCLIP_DEPLOYMENT_MODE=local_trusted
# For private authenticated mode, use:
# PAPERCLIP_DEPLOYMENT_MODE=authenticated
# PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Authenticated mode normally also needs Better Auth secret material:
# BETTER_AUTH_SECRET=
# PAPERCLIP_PUBLIC_URL=http://localhost:3100

# Optional explicit public/auth base settings when needed:
# PAPERCLIP_AUTH_BASE_URL_MODE=auto
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=
# PAPERCLIP_ALLOWED_HOSTNAMES=

# If using external Postgres later:
# DATABASE_URL=postgres://paperclip:paperclip@paperclip-postgres:5432/paperclip

# If using embedded Postgres, leave DATABASE_URL unset.

# Optional backup tuning:
# PAPERCLIP_DB_BACKUP_ENABLED=true
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30

# Optional storage overrides:
# PAPERCLIP_STORAGE_PROVIDER=local_disk
# PAPERCLIP_STORAGE_LOCAL_DIR=/paperclip/instances/paperclip-prod/data/storage
